# === Obrigatórias ===
# Chave da API do Groq (https://console.groq.com/keys)
GROQ_API_KEY=coloque_sua_chave_groq_aqui

# Chave da API do OMDb (https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=coloque_sua_chave_omdb_aqui

# === Opcionais ===
# Modelo do Groq (padrão: llama-3.3-70b-versatile — suporta function calling)
GROQ_MODEL=llama-3.3-70b-versatile

# Porta HTTP (Render injeta automaticamente)
PORT=3000

# Nível de log (trace, debug, info, warn, error)
LOG_LEVEL=info

# Origens permitidas no CORS (separadas por vírgula). Use * somente em dev.
CORS_ORIGINS=*

# Token opcional para autenticar chamadas do Blip (recomendado em produção)
# Se definido, o cliente deve enviar: Authorization: Bearer <valor>
AGENT_AUTH_TOKEN=

# Limites de rate-limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
